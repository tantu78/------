@startuml 校园约球平台系统架构图
' 样式设置
skinparam component {
    BackgroundColor #E3F2FD
    BorderColor #1976D2
}

skinparam database {
    BackgroundColor #FFF8E1
    BorderColor #FF8F00
}

skinparam node {
    BackgroundColor #F5F5F5
    BorderColor #616161
}

skinparam interface {
    BackgroundColor #E8F5E9
    BorderColor #388E3C
}

' 前端层
node "前端层 (Frontend)" {
    [首页 - 活动列表] as index
    [活动详情页] as detail
    [发起活动页] as create
    [个人中心页] as profile
    [地图选点页] as mapPage
    [登录/注册页] as login
    [好友列表页] as friends
    [通知中心页] as notifications
    [管理后台] as admin
}

' API网关层
node "RESTful API" {
    interface "HTTP/JSON" as http
}

' 控制层
node "Controller层" {
    [ActivityController] as activityCtrl
    [UserController] as userCtrl
    [VenueController] as venueCtrl
    [EvaluationController] as evalCtrl
    [FriendController] as friendCtrl
    [NotificationController] as notifyCtrl
    [AdminController] as adminCtrl
    [FileUploadController] as fileCtrl
}

' 业务逻辑层
node "Service层" {
    [ActivityService] as activitySvc
    [UserService] as userSvc
    [VenueService] as venueSvc
    [EvaluationService] as evalSvc
    [FriendService] as friendSvc
    [NotificationService] as notifySvc
}

' 数据访问层
node "Repository层 (Spring Data JPA)" {
    [ActivityRepository] as activityRepo
    [UserRepository] as userRepo
    [VenueRepository] as venueRepo
    [ActivityParticipantRepository] as participantRepo
    [FriendRelationRepository] as friendRepo
    [EvaluationRepository] as evalRepo
    [NotificationRepository] as notifyRepo
    [ActivityRecommendRepository] as recommendRepo
    [ActivityAuditLogRepository] as auditRepo
}

' 数据层
database "MySQL数据库" {
    [user表] as userTable
    [venue表] as venueTable
    [activity表] as activityTable
    [activity_participant表] as participantTable
    [friend_relation表] as friendTable
    [evaluation表] as evalTable
    [notification表] as notifyTable
    [activity_recommend表] as recommendTable
    [activity_audit_log表] as auditTable
}

' 基础设施层
node "基础设施" {
    [Token认证] as auth
    [Swagger文档] as swagger
    [CORS跨域] as cors
    [定时任务] as scheduler
}

' 关系定义
index --> http
detail --> http
create --> http
profile --> http
mapPage --> http
login --> http
friends --> http
notifications --> http
admin --> http

http --> activityCtrl
http --> userCtrl
http --> venueCtrl
http --> evalCtrl
http --> friendCtrl
http --> notifyCtrl
http --> adminCtrl
http --> fileCtrl

activityCtrl --> activitySvc
userCtrl --> userSvc
venueCtrl --> venueSvc
evalCtrl --> evalSvc
friendCtrl --> friendSvc
notifyCtrl --> notifySvc
adminCtrl --> activitySvc

activitySvc --> activityRepo
activitySvc --> participantRepo
activitySvc --> recommendRepo
userSvc --> userRepo
venueSvc --> venueRepo
evalSvc --> evalRepo
friendSvc --> friendRepo
notifySvc --> notifyRepo
activitySvc --> auditRepo

activityRepo --> activityTable
userRepo --> userTable
venueRepo --> venueTable
participantRepo --> participantTable
friendRepo --> friendTable
evalRepo --> evalTable
notifyRepo --> notifyTable
recommendRepo --> recommendTable
auditRepo --> auditTable

auth -[hidden]- http
swagger -[hidden]- auth
cors -[hidden]- swagger
scheduler -[hidden]- cors

@enduml
